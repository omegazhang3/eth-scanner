# EVM Scanner Configuration

# Chains to scan (comma-separated, case-insensitive partial match)
# Leave empty to scan ALL chains
# Examples:
#   CHAINS=eth,bsc,polygon
#   CHAINS=ethereum,arbitrum,base,optimism
#   CHAINS=ethereum          # only Ethereum mainnet
CHAINS=

# Whitelist addresses (comma-separated, case-insensitive)
# If a generated wallet matches any of these, it will be SKIPPED (not scanned)
# Example: WHITELIST=0x1234...abcd,0x5678...ef01
WHITELIST=
